# =====================================================================
# Frontend environment reference. Copy to frontend/.env.local.
# Next.js reads .env.local automatically. NEXT_PUBLIC_ = exposed to browser.
# These are the only two variables the app reads (see src/lib/config.ts).
# =====================================================================

# Local dev (backend on the same machine):
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000

# For a remote server, use the VM's IP/domain (and https/wss once TLS is set up):
# NEXT_PUBLIC_API_BASE_URL=https://your-domain
# NEXT_PUBLIC_WS_BASE_URL=wss://your-domain
