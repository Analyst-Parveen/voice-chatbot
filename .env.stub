# =====================================================================
# STUB MODE — build & test the whole app on a low-config PC, no Docker.
# No AI models are loaded. STT/TTS/LLM/RAG return canned responses.
# Fastest way to develop UI, streaming, WebSockets, and DB persistence.
#   Usage:  cp .env.stub .env
# =====================================================================

RUN_MODE=stub

APP_NAME=voice-ai-assistant
APP_ENV=development
LOG_LEVEL=DEBUG
LOG_JSON=false

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000

# No SQL Server needed — use the SQLite dev fallback.
DB_BACKEND=sqlite
SQLITE_PATH=./voiceai_dev.sqlite3
DB_SCHEMA=voiceai

# Not used in stub mode (kept for parity).
OLLAMA_URL=http://localhost:11434
LLM_MODEL=stub
QDRANT_URL=
QDRANT_PATH=./qdrant_local
QDRANT_COLLECTION=company_knowledge
WHISPER_MODEL=stub
EMBED_MODEL=stub
RERANKER_MODEL=stub
PIPER_VOICE=stub

# RAG off in stub: pure echo chat, no knowledge base needed.
RAG_ENABLED=false
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.35
RAG_USE_RERANKER=false
RAG_MIN_CONTEXT_CHARS=40

RATE_LIMIT_PER_MINUTE=120
AUTH_ENABLED=false
JWT_SECRET=dev_secret
