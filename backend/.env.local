# Local development — tiny real models on a weak PC.
#   cp .env.local .env

RUN_MODE=local-light

APP_NAME=voice-ai-assistant
APP_ENV=development
LOG_LEVEL=DEBUG
LOG_JSON=false

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

DB_BACKEND=sqlite
SQLITE_PATH=./voiceai_dev.sqlite3
DB_SCHEMA=voiceai

OLLAMA_URL=http://localhost:11434
LLM_MODEL=qwen2.5:0.5b
OLLAMA_TIMEOUT_SECONDS=600

QDRANT_URL=
QDRANT_PATH=./qdrant_local
QDRANT_COLLECTION=company_knowledge

WHISPER_MODEL=small
EMBED_MODEL=lexical
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
PIPER_VOICE=hi_IN-priyamvada-medium

RAG_ENABLED=true
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.2
RAG_USE_RERANKER=false
RAG_MIN_CONTEXT_CHARS=20

RATE_LIMIT_PER_MINUTE=60
AUTH_ENABLED=false
JWT_SECRET=dev_secret
