# Azure VM / production backend template.
#   cp .env.azure .env
#   bash backend/deploy/azure/backend-setup.sh

RUN_MODE=local-light

APP_NAME=voice-ai-assistant
APP_ENV=production
LOG_LEVEL=INFO
LOG_JSON=true

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
CORS_ORIGINS=https://your-company-website.com

DB_BACKEND=sqlite
SQLITE_PATH=./voiceai_prod.sqlite3
# DB_BACKEND=mssql
# MSSQL_HOST=your-sql-server-host
# MSSQL_PORT=1433
# MSSQL_DB=IAPL
# MSSQL_USER=voiceai_app
# MSSQL_PASSWORD=change_me
# MSSQL_DRIVER=ODBC Driver 17 for SQL Server
DB_SCHEMA=voiceai

OLLAMA_URL=http://localhost:11434
LLM_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SECONDS=600

QDRANT_URL=
QDRANT_PATH=./qdrant_local
QDRANT_COLLECTION=company_knowledge

REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

WHISPER_MODEL=small
WHISPER_DEVICE=cpu
EMBED_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
PIPER_VOICE=hi_IN-priyamvada-medium

RAG_ENABLED=true
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.4
RAG_USE_RERANKER=true
RAG_MIN_CONTEXT_CHARS=40

RATE_LIMIT_PER_MINUTE=60
AUTH_ENABLED=true
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
