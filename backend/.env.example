# Backend environment template — copy to .env and edit.
#   cp .env.example .env
#   cp .env.local .env      (local dev, tiny models)
#   cp .env.azure .env        (Azure VM / production backend)
#   cp .env.stub .env         (stub mode, no AI)
#
# Frontend URLs live in frontend/.env.local or frontend/.env.production

RUN_MODE=stub

APP_NAME=voice-ai-assistant
APP_ENV=development
LOG_LEVEL=INFO
LOG_JSON=false

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

DB_BACKEND=sqlite
SQLITE_PATH=./voiceai_dev.sqlite3
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DB=IAPL
MSSQL_USER=sa
MSSQL_PASSWORD=change_me
MSSQL_DRIVER=ODBC Driver 17 for SQL Server
DB_SCHEMA=voiceai

OLLAMA_URL=http://localhost:11434
LLM_MODEL=qwen2.5:0.5b
OLLAMA_TIMEOUT_SECONDS=600

QDRANT_URL=
QDRANT_PATH=./qdrant_local
QDRANT_COLLECTION=company_knowledge

WHISPER_MODEL=small
WHISPER_DEVICE=cpu
EMBED_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
PIPER_VOICE=hi_IN-priyamvada-medium

RAG_ENABLED=false
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.35
RAG_USE_RERANKER=true
RAG_MIN_CONTEXT_CHARS=40

REDIS_URL=
CACHE_TTL_SECONDS=3600

RATE_LIMIT_PER_MINUTE=60
AUTH_ENABLED=false
JWT_SECRET=change_me_in_production
