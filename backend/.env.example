# =====================================================================
# Backend environment reference. Copy to backend/.env and fill in values.
# The runtime backend/.env is gitignored; THIS example is safe (no secrets).
# =====================================================================

RUN_MODE=local-light            # stub | local-light | docker-full

APP_NAME=voice-ai-assistant
APP_ENV=development              # development | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000     # comma-separated allowed frontend origins

# ---- Database -------------------------------------------------------
# Option A (default): SQLite — a local file, zero setup.
DB_BACKEND=sqlite
SQLITE_PATH=./voiceai_dev.sqlite3
DB_SCHEMA=voiceai

# Option B: Microsoft SQL Server. Set DB_BACKEND=mssql and fill these in:
# DB_BACKEND=mssql
# MSSQL_HOST=your_sql_server_host_or_ip
# MSSQL_PORT=1433
# MSSQL_DB=IAPL
# MSSQL_USER=your_sql_user
# MSSQL_PASSWORD=your_password
# MSSQL_DRIVER=ODBC Driver 17 for SQL Server

# ---- LLM via Ollama (must be running: ollama serve) -----------------
OLLAMA_URL=http://localhost:11434
LLM_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SECONDS=600
LLM_MAX_TOKENS=1024

# ---- Speech to text -------------------------------------------------
WHISPER_MODEL=small              # tiny | base | small | medium
WHISPER_DEVICE=cpu               # cpu | cuda

# ---- Text to speech -------------------------------------------------
PIPER_VOICE=hi_IN-priyamvada-medium

# ---- Vector DB (embedded Qdrant) ------------------------------------
QDRANT_URL=                      # empty = embedded local folder
QDRANT_PATH=./qdrant_local
QDRANT_COLLECTION=company_knowledge
FAQ_COLLECTION=faq_intents

# ---- RAG ------------------------------------------------------------
EMBED_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_ENABLED=true
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.35
RAG_USE_RERANKER=true
RAG_MIN_CONTEXT_CHARS=40
FAQ_SCORE_THRESHOLD=0.72

# ---- Security -------------------------------------------------------
RATE_LIMIT_PER_MINUTE=120
AUTH_ENABLED=false
JWT_SECRET=change_me_to_a_long_random_string
