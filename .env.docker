# =====================================================================
# DOCKER-FULL MODE — production deployment on the server via Compose.
# Full-size models. Hostnames are Docker Compose SERVICE NAMES.
# SQL Server is your EXISTING external database — set the real creds below.
#   Usage:  cp .env.docker .env  &&  docker compose up -d
# =====================================================================

RUN_MODE=docker-full

APP_NAME=voice-ai-assistant
APP_ENV=production
LOG_LEVEL=INFO
LOG_JSON=true

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Set to your real website origin(s) in production.
CORS_ORIGINS=https://your-company-website.com

# In the browser these must be the PUBLIC URLs of the deployed backend.
NEXT_PUBLIC_API_BASE_URL=https://your-server-domain
NEXT_PUBLIC_WS_BASE_URL=wss://your-server-domain

# Production uses the existing MS SQL Server (NOT containerized here).
DB_BACKEND=mssql
MSSQL_HOST=host.docker.internal        # or the real SQL Server host/IP
MSSQL_PORT=1433
MSSQL_DB=CompanyDB
MSSQL_USER=voiceai_app
MSSQL_PASSWORD=change_me_in_production
MSSQL_DRIVER=ODBC Driver 17 for SQL Server
DB_SCHEMA=voiceai

# Compose service names resolve on the internal Docker network.
OLLAMA_URL=http://ollama:11434
LLM_MODEL=qwen2.5:3b

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=company_knowledge

# Redis: answer cache + shared rate-limit counter + helpdesk state.
# (Leave empty to disable — the app runs identically without it.)
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600

WHISPER_MODEL=small
EMBED_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
PIPER_VOICE=en_US-lessac-medium

RAG_ENABLED=true
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.4
RAG_USE_RERANKER=true
RAG_MIN_CONTEXT_CHARS=40

RATE_LIMIT_PER_MINUTE=60
AUTH_ENABLED=true
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
