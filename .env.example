# =====================================================================
# Voice AI Assistant — Environment Template
# ---------------------------------------------------------------------
# Copy ONE of the ready-made files to `.env`:
#   cp .env.stub  .env   → build/test the whole app, no AI load (weak PC)
#   cp .env.local .env   → run tiny models natively (weak PC)
#   cp .env.azure .env   → full models natively on the server VM
# Never commit your real `.env`. This template is safe to commit.
# =====================================================================

# ---- Run mode: stub | local-light ----
RUN_MODE=stub

# ---- App ----
APP_NAME=voice-ai-assistant
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false               # true = structured JSON logs (prod)

# ---- Backend server ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ---- CORS (comma-separated allowed origins) ----
CORS_ORIGINS=http://localhost:3000

# ---- Frontend ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000

# ---- Database ----
# DB_BACKEND: sqlite (dev fallback, no SQL Server) | mssql (production)
DB_BACKEND=sqlite
SQLITE_PATH=./voiceai_dev.sqlite3
# MS SQL Server connection (used only when DB_BACKEND=mssql)
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DB=CompanyDB
MSSQL_USER=sa
MSSQL_PASSWORD=change_me
MSSQL_DRIVER=ODBC Driver 17 for SQL Server
DB_SCHEMA=voiceai

# ---- Ollama (LLM) — ignored in stub mode ----
OLLAMA_URL=http://localhost:11434
LLM_MODEL=qwen2.5:0.5b

# ---- Qdrant (vector DB) — ignored in stub mode ----
# In local-light, leave QDRANT_URL empty to use embedded local mode.
QDRANT_URL=
QDRANT_PATH=./qdrant_local
QDRANT_COLLECTION=company_knowledge

# ---- Models (sizes differ per mode) ----
WHISPER_MODEL=small
EMBED_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
PIPER_VOICE=hi_IN-priyamvada-medium

# ---- RAG tuning ----
# RAG_ENABLED: false = echo/no-grounding (fast dev). true = retrieve + enforce
# grounding (answers come only from ingested knowledge).
RAG_ENABLED=false
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.35
RAG_USE_RERANKER=true
RAG_MIN_CONTEXT_CHARS=40

# ---- Security ----
RATE_LIMIT_PER_MINUTE=60
AUTH_ENABLED=false
JWT_SECRET=change_me_in_production
