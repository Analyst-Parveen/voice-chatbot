# =====================================================================
# AZURE VM — NO-DOCKER production deployment (native installs).
# Same tools & accuracy as docker-full: qwen2.5:3b, bge-m3 + reranker,
# Whisper small, Piper voices, Redis cache — just installed natively.
#   Usage on the VM:  cp .env.azure .env   # then edit the values marked below
#   Setup:            bash deploy/azure/backend-setup.sh
#                     bash deploy/azure/frontend-setup.sh
# =====================================================================

RUN_MODE=local-light

APP_NAME=voice-ai-assistant
APP_ENV=production
LOG_LEVEL=INFO
LOG_JSON=true

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# EDIT: your real website origin(s).
CORS_ORIGINS=https://your-company-website.com

# EDIT: the PUBLIC URLs of this server (browser-facing). Before you have a
# domain/TLS you can temporarily use http://<VM_IP> and ws://<VM_IP>.
NEXT_PUBLIC_API_BASE_URL=https://your-server-domain
NEXT_PUBLIC_WS_BASE_URL=wss://your-server-domain

# --- Database: sqlite works out of the box; switch to mssql when ready ---
DB_BACKEND=sqlite
SQLITE_PATH=./voiceai_prod.sqlite3
# DB_BACKEND=mssql
# MSSQL_HOST=your-sql-server-host
# MSSQL_PORT=1433
# MSSQL_DB=CompanyDB
# MSSQL_USER=voiceai_app
# MSSQL_PASSWORD=change_me
# MSSQL_DRIVER=ODBC Driver 17 for SQL Server
DB_SCHEMA=voiceai

# --- Ollama runs natively on the VM (installed by backend-setup.sh) ---
OLLAMA_URL=http://localhost:11434
LLM_MODEL=qwen2.5:3b

# --- Qdrant: EMBEDDED mode (no server, no install — same engine/accuracy).
# IMPORTANT: embedded mode = exactly ONE backend process (the systemd unit
# runs a single worker) and the backend must be STOPPED during ingestion. ---
QDRANT_URL=
QDRANT_PATH=./qdrant_local
QDRANT_COLLECTION=company_knowledge

# --- Redis: native redis-server on localhost (installed by setup script) ---
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# --- Full-size models (same accuracy as the Docker server profile) ---
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
EMBED_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
PIPER_VOICE=hi_IN-priyamvada-medium

RAG_ENABLED=true
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.4
RAG_USE_RERANKER=true
RAG_MIN_CONTEXT_CHARS=40

RATE_LIMIT_PER_MINUTE=60
AUTH_ENABLED=true
# EDIT: a long random secret.
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
