# ---- Environment / secrets (runtime + templates — never commit) ----
.env
backend/.env
**/.env.azure
**/.env.local
**/.env.production
# NOTE: .env.example files are intentionally COMMITTED (placeholders only, no
# secrets) so anyone can see which variables to set.

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/

# ---- Node / Next.js ----
node_modules/
.next/
out/

# ---- Built widget bundle ----
frontend/public/widget.js
frontend/src/embed/widget.generated.css
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- AI models & data ----
/models/
# Ignore data/ EXCEPT the extracted markdown, which IS committed so the gathered
# company knowledge (text) travels with the repo and never needs re-fetching.
# The embeddings (qdrant_local) and the ingest manifest stay local — a fresh
# clone rebuilds them from this text via backend-setup.ps1 (its ingestion step).
/data/*
!/data/extracted/
/data/extracted/*
!/data/extracted/*.md
*.gguf
*.onnx
*.bin
*.pt

# ---- Vector store / db local files ----
qdrant_storage/
qdrant_local/
*.sqlite3
*.db

# ---- IDE / OS ----
.idea/
.vscode/
.DS_Store
Thumbs.db
*.log
*.tsbuildinfo

# ---- Legacy root env (moved to backend/ and frontend/) ----
/.env
/.env.local
/.env.azure
/.env.stub
